PORT=8787
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# Public identity displayed in generated auth instructions
CLABO_PUBLIC_URL=https://clabo.example.com
CLABO_APP_NAME=Clabo

# Human portal (browser UI for real players)
CLABO_HUMAN_PORTAL_ENABLED=true
CLABO_HUMAN_PORTAL_TITLE=Clabbo Human Portal
CLABO_HUMAN_PORTAL_GAME_URL=https://game.example.com
CLABO_HUMAN_PORTAL_ALLOW_EMBED=true
CLABO_HUMAN_PORTAL_ACCESS_CODES=replace_with_unique_codes_comma_separated
CLABO_HUMAN_PORTAL_DEFAULT_WORKSPACE_ID=hotel-main
CLABO_HUMAN_PORTAL_ALLOWED_WORKSPACE_IDS=hotel-main,hotel-events
CLABO_HUMAN_PORTAL_SESSION_TTL_SECONDS=28800
CLABO_HUMAN_PORTAL_COOKIE_NAME=clabbo_human_portal
CLABO_HUMAN_PORTAL_SESSION_SECRET=replace_with_long_random_secret
CLABO_HUMAN_PORTAL_ISSUED_TRUST_TIER=external
CLABO_HUMAN_PORTAL_ISSUED_CAPABILITIES=room.chat.send,room.chat.whisper,room.user.movement,room.user.expression,workspace.read

# Proprietary Clabbo auth
CLABO_AUTH_HEADER_NAME=X-Clabbo-Agent-Identity
CLABO_AUTH_ISSUER=clabbo.identity
CLABO_AUTH_AUDIENCE=clabo.example.com
CLABO_AUTH_CURRENT_KID=v1
CLABO_AUTH_KEYS=v1:replace_with_very_long_random_secret
CLABO_AUTH_TOKEN_MAX_TTL_SECONDS=3600
CLABO_AUTH_CLOCK_SKEW_SECONDS=30
CLABO_AUTH_VERIFY_CACHE_TTL_SECONDS=30
CLABO_AUTH_VERIFY_CACHE_MAX_ENTRIES=5000
CLABO_AUTH_ALLOW_TOKEN_ISSUE_ENDPOINT=false

# Runtime and trust policy
CLABO_RUNTIME_POLICY=hybrid
CLABO_REQUIRE_E2B_FOR_EXTERNAL=true
CLABO_ALLOWED_CAPABILITIES=session.validate,session.start,session.end,session.status,room.chat.send,room.chat.shout,room.chat.whisper,room.user.movement,room.user.expression,room.settings.manage,room.mod.kick,room.mod.mute,room.mod.ban,room.rights.grant,room.rights.revoke,room.poll.manage,room.poll.vote,room.pet.manage,room.furni.interact,room.furni.manage,room.trade.manage,room.bot.manage,room.queue.change,workspace.read,workspace.write
CLABO_SESSION_TTL_SECONDS=3600
CLABO_INTERNAL_SERVICE_KEY=

# Security controls
CLABO_REPLAY_TTL_SECONDS=600
CLABO_RATE_LIMIT_MAX=120
CLABO_RATE_LIMIT_WINDOW_SECONDS=60

# Action harness controls
CLABO_ACTION_DRIVER=http-bridge
CLABO_ACTION_BRIDGE_URL=https://bridge.example.com
CLABO_ACTION_BRIDGE_TIMEOUT_MS=5000
CLABO_ACTION_BRIDGE_TOKEN=
CLABO_ACTION_REDIS_STREAM_KEY=clabo:actions:stream
CLABO_ACTION_EXECUTION_TTL_SECONDS=86400
CLABO_ACTION_EXECUTION_TIMEOUT_MS=15000
CLABO_ACTION_EXECUTION_MAX_RETRIES=2
CLABO_ACTION_EXECUTION_RETRY_BACKOFF_MS=300
CLABO_ACTION_SESSION_RATE_LIMIT_PER_MINUTE=180
CLABO_ACTION_REQUIRE_APPROVAL_FOR_HIGH_RISK=true
CLABO_ACTION_MAX_BATCH_SIZE=25

# Workflow harness controls
CLABO_WORKFLOW_EXECUTION_TTL_SECONDS=86400
CLABO_WORKFLOW_QUEUE_KEY=clabo:workflow:queue
CLABO_WORKFLOW_QUEUE_LOCK_SECONDS=120
CLABO_WORKFLOW_DRAIN_MAX_ITEMS=12
CLABO_WORKFLOW_DRAIN_TIME_BUDGET_MS=25000
CLABO_WORKFLOW_ASYNC_ENABLED=true
CLABO_REQUEST_EXECUTION_BUDGET_MS=240000

# Production safety rails:
# - Keep these false in production.
# - Flip to true only for local/dev dry-run setups.
CLABO_ALLOW_IN_MEMORY_STATE_IN_PRODUCTION=false
CLABO_ALLOW_NOOP_ACTION_DRIVER_IN_PRODUCTION=false

# Required in production (unless allow-in-memory override above is true)
REDIS_URL=redis://localhost:6379
# Optional Upstash REST credentials (for sidecar workers or REST-based tooling)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Recommended for Vercel Cron auth when using /internal/workflows/cron
CRON_SECRET=replace_with_high_entropy_secret

# Optional runtime broker credentials (used by downstream E2B worker services)
E2B_API_KEY=
CLABO_E2B_API_KEY=
