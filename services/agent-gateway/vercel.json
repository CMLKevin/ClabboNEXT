{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    }
  ],
  "crons": [
    {
      "path": "/api/agent/v1/internal/workflows/cron",
      "schedule": "*/1 * * * *"
    }
  ]
}
